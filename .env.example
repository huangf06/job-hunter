# =============================================================================
# Job Hunter - API Keys & Endpoints
# =============================================================================
# NEVER commit this file to git!
# Copy .env.example to .env and fill in your values.
# =============================================================================

# --- DeepSeek (primary, cheap batch processing) ---
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# --- Claude Opus (via proxy, optional fallback) ---
ANTHROPIC_API_KEY=your-opus-api-key-here
ANTHROPIC_BASE_URL=https://codesome.cn/v1

# --- Kimi VIP ---
KIMI_API_KEY=your-kimi-vip-key-here
KIMI_BASE_URL=https://api.kimi.com/v1

# --- Gmail IMAP (for reading interview emails) ---
# Get App Password from: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
